{
  "name": "vite-plugin-ts-mono-alias",
  "version": "1.2.0",
  "description": "Vite plugin ts resolve for mono-repo projects.",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "keywords": [
    "ts mono-repo alias",
    "ts mono-repo resolve",
    "vite plugin ts mono-repo alias src"
  ],
  "module": "dist/index.esm.js",
  "type": "module",
  "scripts": {
    "build": "rollup -c && npm run build:types",
    "build:types": "tsc -d --emitDeclarationOnly",
    "release": "semantic-release",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "npm run lint -- --fix"
  },
  "author": "garyshen <grinson50@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/gary-Shen/vite-plugin-ts-mono-alias.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-typescript": "^10.0.1",
    "@semantic-release/commit-analyzer": "^9.0.2",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^8.0.7",
    "@semantic-release/release-notes-generator": "^10.0.3",
    "@types/node": "^18.11.15",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^0.34.6",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "rollup": "^3.7.4",
    "semantic-release": "^19.0.5",
    "tslib": "^2.4.1",
    "typescript": "^5.2.2",
    "vite": "^4.0.1",
    "vitest": "^0.34.6"
  },
  "dependencies": {
    "@manypkg/get-packages": "^1.1.3",
    "tsconfig-paths": "^4.1.1"
  }
}
